# === Режим мониторинга ===
# twitch   — прямой опрос Twitch API (требует TWITCH_CLIENT_ID/SECRET)
# telegram — слушать уведомления от @twiMonBot (требует TELEGRAM_API_*)
MONITOR_MODE=twitch

# === Twitch (только для MONITOR_MODE=twitch) ===
# Создать приложение на https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret

# === Telegram-бот ===
# Создать бота через @BotFather
TELEGRAM_BOT_TOKEN=1234567890:AABBCCxxx
# Chat ID куда слать уведомления (свой или группы). Узнать: написать боту /start, затем
# curl https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=123456789

# === Telegram user-аккаунт (только для MONITOR_MODE=telegram) ===
# API_ID и API_HASH получить на https://my.telegram.org → API development tools
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890
# Номер телефона аккаунта, подключённого к @twiMonBot (с кодом страны)
TELEGRAM_PHONE=+79001234567

# === Яндекс (Алиса / Яндекс Станция) ===
# Токен OAuth Яндекса. Получить:
# 1. Откройте в браузере (войдя в нужный аккаунт):
#    https://oauth.yandex.ru/authorize?response_type=token&client_id=23cabbbdc6cd418abb4b39c32c41195d
# 2. Разрешите доступ, скопируйте access_token из адресной строки
YANDEX_TOKEN=your_yandex_oauth_token

# ID устройства Яндекс Станции.
# Получить автоматически: python -m bot.alice_discovery
YANDEX_DEVICE_ID=your_station_device_id

# Платформа: yandexstation | yandexstation_2 | yandexmini | yandexmini_2 | yandexmicro
YANDEX_PLATFORM=yandexstation_2

# === Email (резервный канал — только для ошибок, если Telegram недоступен) ===
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=your@gmail.com
EMAIL_TO=alerts@example.com

# === Настройки мониторинга (только для MONITOR_MODE=twitch) ===
# Интервал опроса Twitch API в секундах (минимум 30, рекомендуется 60)
POLL_INTERVAL=60

# Путь к базе данных
DB_PATH=data/bot.db
